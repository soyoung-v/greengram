<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.green.greengram.application.feedcomment.FeedCommentMapper">
    <!-- 인터페이스에 있는 메소드와 연결. 메소드명은 id랑 같다. -->

    <insert id="save" useGeneratedKeys="true" keyProperty="commentId">
        INSERT INTO feed_comment
        SET user_id = #{signedUserId}
        , feed_id = #{feedId}
        , feed_comment = #{comment}
    </insert>

</mapper>